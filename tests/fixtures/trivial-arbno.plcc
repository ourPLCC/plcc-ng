token NUM   '\d+'
token PLUS  '\+'
token COMMA ','
skip  SPACE '\s+'
%
<Program>          ::= <Rands:rands>
<Rands>            **= <Expr:expr> +COMMA
<Expr:LitExpr>     ::= <NUM:num>
<Expr:AddExpr>     ::= PLUS <Rands:rands>
%
Python
Program
%%%
def _run(self):
    return str([e.eval() for e in self.rands.exprList])
%%%
LitExpr
%%%
def eval(self):
    return int(self.num.lexeme)
%%%
AddExpr
%%%
def eval(self):
    return sum(e.eval() for e in self.rands.exprList)
%%%
