{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TokenStreamRecord",
  "description": "One JSONL record from plcc-tokens stdout.",
  "definitions": {
    "SourcePosition": {
      "type": "object",
      "required": ["file", "line", "column"],
      "properties": {
        "file":   { "type": ["string", "null"] },
        "line":   { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "AttemptEntry": {
      "type": "object",
      "required": ["name", "regex", "lexeme", "char_count", "is_skip", "winner"],
      "properties": {
        "name":       { "type": "string" },
        "regex":      { "type": "string" },
        "lexeme":     { "type": "string" },
        "char_count": { "type": "integer", "minimum": 0 },
        "is_skip":    { "type": "boolean" },
        "winner":     { "type": "boolean" }
      }
    }
  },
  "oneOf": [
    {
      "title": "TokenRecord",
      "type": "object",
      "required": ["kind", "name", "lexeme", "source"],
      "properties": {
        "kind": { "type": "string", "const": "token" },
        "name":        { "type": "string" },
        "lexeme":      { "type": "string" },
        "source":      { "$ref": "#/definitions/SourcePosition" },
        "regex":       { "type": "string" },
        "source_line": { "type": "string" },
        "attempts": {
          "type": "array",
          "items": { "$ref": "#/definitions/AttemptEntry" }
        }
      }
    },
    {
      "title": "SkipRecord",
      "type": "object",
      "required": ["kind", "name", "lexeme", "source"],
      "properties": {
        "kind": { "type": "string", "const": "skip" },
        "name":        { "type": "string" },
        "lexeme":      { "type": "string" },
        "source":      { "$ref": "#/definitions/SourcePosition" },
        "regex":       { "type": "string" },
        "source_line": { "type": "string" },
        "attempts": {
          "type": "array",
          "items": { "$ref": "#/definitions/AttemptEntry" }
        }
      }
    },
    {
      "title": "ErrorRecord",
      "type": "object",
      "required": ["kind", "stage", "severity", "source", "lexeme", "message"],
      "properties": {
        "kind":     { "type": "string", "const": "error" },
        "stage":    { "type": "string" },
        "severity": { "type": "string" },
        "source":   { "$ref": "#/definitions/SourcePosition" },
        "lexeme":   { "type": "string" },
        "message":  { "type": "string" }
      }
    }
  ]
}
