{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TreeRecord",
  "description": "One JSONL record from plcc-tree: one complete parse tree.",
  "type": "object",
  "required": ["kind", "rule"],
  "properties": {
    "kind":     { "type": "string", "const": "tree" },
    "rule":     { "type": "string" },
    "children": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": { "type": "string", "enum": ["token", "tree"] }
        }
      }
    }
  }
}
